# ============================================
# AIToolPeak Environment Configuration
# ============================================

# Server Configuration
# Port for Express server (default: 3525)
PORT=3525

# Site URL
# Used for SEO meta tags, sitemap, and canonical URLs
# Development: http://localhost:3525
# Production: https://aitoolpeak.setrox.com.tr
SITE_URL=http://localhost:3525

# Content Paths
# Directory for markdown articles
CONTENT_DIR=./content/articles

# Contact Submissions
# JSON file path for contact form submissions
CONTACT_FILE=./content/contact-submissions.json

# Optional: Analytics
# Google Analytics 4 Measurement ID (optional)
# GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional: Email Notifications
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# CONTACT_EMAIL=admin@aitoolpeak.com
